# Resend — required to send emails from the contact form.
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender. Until you verify a domain in Resend, you must use
# "onboarding@resend.dev" (Resend's shared sandbox sender). Once your
# domain is verified, switch to e.g. "GG Software <hello@ggsoftware.cz>".
RESEND_FROM=GG Software <onboarding@resend.dev>

# Recipient inbox. Defaults to siteConfig.email — set this to override
# (e.g. when testing locally you might route to your personal inbox).
CONTACT_TO=ggsoftware.cz@gmail.com

# Cloudflare Turnstile — optional. When both keys are set, the contact
# form renders the widget and the API verifies the token server-side.
# When unset, the form falls back to the honeypot only.
# https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
